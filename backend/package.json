{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "db:migrate": "node dist/db/migrate.js",
    "db:seed": "node dist/db/seed.js",
    "start": "npm run db:migrate && node dist/index.js",
    "build": "rimraf dist && npx tsc",
    "dev": "npx tsx watch src/index.ts",
    "db:migrate:dev": "npx tsx src/db/migrate.ts",
    "db:seed:dev": "npx tsx src/db/seed.ts",
    "db-init": "npm run db:migrate:dev && npm run db:seed:dev",
    "development": "npm run db:migrate:dev && npm run db:seed:dev && npm run dev"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "jsonrepair": "^3.14.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.2.0",
    "pg": "^8.21.0",
    "sharp": "^0.35.3",
    "tsx": "^4.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.2.0",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "rimraf": "^6.1.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "allowScripts": {
    "bcrypt@6.0.0": true,
    "esbuild@0.28.0": true,
    "fsevents@2.3.3": true
  }
}
