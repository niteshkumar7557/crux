# ─────────────────────────────────────────────────────────────────────────────
# Crux — backend environment
#
# Copy to `.env` and fill in the secrets. Everything here is optional except the
# entries marked REQUIRED: the value shown is the code's default when the
# variable is absent, so a minimal .env still boots (minus the LLM key).
#
# All of these are read in exactly one place — `src/config/index.ts`. The single
# exception is CRUX_SEASON_ZERO; see the Seasons block for why.
#
# The GAME RULES are deliberately NOT here. Score ranges, payouts, the draw
# threshold and the rest are fixed by §15 of docs/game-theory.md, asserted by
# unit tests, and printed to users on /rules — an env var that silently changed
# one would make the product lie. The bottom of this file says where they live.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# Used by docker-compose.dev.yml to create the container's database.
POSTGRES_USER=crux
POSTGRES_PASSWORD=secret
POSTGRES_DB=cruxdb

# REQUIRED — the connection string the app itself uses.
DB_URL=postgresql://crux:secret@localhost:5432/cruxdb

# ── Server ───────────────────────────────────────────────────────────────────
SERVER_PORT=8000
NODE_ENV=development
# Origin allowed by CORS — the frontend's URL.
CLIENT_URL=http://localhost:3000

# ── Auth ─────────────────────────────────────────────────────────────────────
# REQUIRED — replace with a long random string before deploying.
JWT_SECRET=supersecret

# Access-token lifetime (any span jsonwebtoken accepts: 15m, 1h, 7d).
ACCESS_TOKEN_TTL=15m
# Refresh-token lifetime, in days.
REFRESH_TOKEN_DAYS=7
# bcrypt cost factor. Higher is slower and safer; 10 is the common floor.
BCRYPT_ROUNDS=10

# ── LLM provider ─────────────────────────────────────────────────────────────
# REQUIRED — without a key every AI persona fails and no statement can go live.
# LLM_API_KEY takes precedence; GROQ_API_KEY is kept as an alias.
GROQ_API_KEY=->your_groq_api_key_here<-
# LLM_API_KEY=

# Any OpenAI-compatible /chat/completions endpoint. Swapping provider is
# env-only, no code change.
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL_SMART=openai/gpt-oss-120b
LLM_MODEL_FAST=llama-3.3-70b-versatile

# Per-request abort, in ms.
LLM_TIMEOUT_MS=30000
# Attempts after the first one fails.
LLM_RETRIES=2
LLM_TEMPERATURE=0.2
# Default ceiling. Keep it generous: the "smart" model is a reasoning model and
# its reasoning tokens count toward this, so a low value returns truncated JSON.
LLM_MAX_TOKENS=3000

# ── Seasons ──────────────────────────────────────────────────────────────────
# The launch month, as YYYY-MM. Season 0 is that month, Season 1 the next.
# SET THIS BEFORE LAUNCH: any earlier month is arithmetically negative, so the
# UI reads "Season -1" and the rollover job correctly awards nothing.
#
# Read directly by `src/economy/season.logic.ts` rather than through config —
# it is a pure module, and importing config would pull `dotenv/config` into the
# season unit tests and make them depend on your local .env.
CRUX_SEASON_ZERO=2026-08

# ── Background jobs ──────────────────────────────────────────────────────────
# Three in-process pollers. Lower values mean more DB load, not more correctness.
CONCLUSION_TICK_MS=60000
# Max debates concluded per tick (each costs one LLM call).
CONCLUSION_BATCH=20
FEATURING_TICK_MS=300000
SEASON_ROLLOVER_TICK_MS=3600000

# ── Limits ───────────────────────────────────────────────────────────────────
# Comments handed to the Verdict Judge. Caps prompt size and cost per verdict.
VERDICT_MAX_COMMENTS=40
# Rows returned by the leaderboard endpoints.
LEADERBOARD_ROWS=50
# URLs in the generated sitemap.
SITEMAP_ROWS=5000
# Max avatar upload, in megabytes.
AVATAR_UPLOAD_MB=5
# Concluded debates listed on a profile.
PROFILE_HISTORY_ROWS=10
# Live debates listed on a profile.
PROFILE_LIVE_ROWS=6
# Weeks of the logic ledger charted on a profile.
PROFILE_LEDGER_WEEKS=12

# ── Stress seeder (`npm run db:seed:stress` only) ────────────────────────────
# These defaults generate ~1M statements and ~6M comments.
SEED_USERS=10000
SEED_STATEMENTS=1000000
SEED_MAX_COMMENTS=12
SEED_BATCH=1000000

# ─────────────────────────────────────────────────────────────────────────────
# Game rules are not configurable. They live here, and in §15 of the spec:
#
#   src/ai/analyst.logic.ts       score range 1-8, standalone cap 5,
#                                 3 full-value comments before halving
#   src/ai/verdict.logic.ts       draw margin 5, MVP +25, win +10,
#                                 loss -5, author +5
#   src/jobs/featuring.logic.ts   Main Stage size 4, heat window 6h,
#                                 balance floor
#   src/economy/season.logic.ts   one calendar month, UTC
#
# Changing one means changing the spec, the code, its unit test, and the copy
# users are shown — together, on purpose.
# ─────────────────────────────────────────────────────────────────────────────
