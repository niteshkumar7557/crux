# ─────────────────────────────────────────────────────────────────────────────
# Crux — frontend environment
#
# Copy to `.env`. Both values are NEXT_PUBLIC_*, so they are inlined into the
# client bundle at build time — never put a secret here.
#
# Next.js reads these at build time, not run time: after changing either one,
# restart `npm run dev` (or rebuild) or the old value stays baked in.
# ─────────────────────────────────────────────────────────────────────────────

# Where the Express API lives. Used by `app/axios.server.ts` for server-side
# fetches and by the `/api/*` rewrite proxy in `next.config.ts`.
NEXT_PUBLIC_API_URL=http://localhost:8000

# This site's own public origin. Used for canonical URLs, OpenGraph tags, the
# verdict share card, robots.txt and sitemap.xml.
#
# SET THIS IN PRODUCTION. It falls back to http://localhost:3000, so leaving it
# unset ships share links and a sitemap pointing at localhost.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
